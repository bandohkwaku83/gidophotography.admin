# Public site URL for client gallery links (SMS, share clipboard, Open Graph).
# Set this when developing locally so uploads/SMS use the live URL, not localhost.
NEXT_PUBLIC_SITE_URL=https://gidophotography.com

# Backend used by Next.js rewrites (/api/* → this host) and by `app/uploads/[...path]/route.ts`
# when serving `/uploads/*` through the Next app. Default: https://api.gidophotography.com
# BACKEND_API_URL=https://api.gidophotography.com

# Optional: comma-separated hostnames (or full https URLs) allowed for `next/image` in addition
# to the API and default S3 bucket. Example: your CloudFront domain or another S3 virtual host.
# NEXT_PUBLIC_IMAGE_REMOTE_HOSTS=img.example.com,https://cdn.example.com

# Optional: comma-separated hostnames whose absolute `/uploads/...` URLs should become same-origin.
# Default includes api.gidophotography.com.
# NEXT_PUBLIC_UPLOADS_PROXY_HOSTS=api.gidophotography.com,staging.example.com

# Leave NEXT_PUBLIC_API_URL unset so the browser calls same-origin /api/... (no CORS).
# Only set this if the app must talk to the API host directly (then configure API CORS).
# NEXT_PUBLIC_API_URL=https://api.gidophotography.com

# Local backend during API development:
# BACKEND_API_URL=http://localhost:8000
